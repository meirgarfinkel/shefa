# Production environment variables for Vercel + Neon + Upstash + Railway
# Copy the relevant vars into each service's environment settings.
# Never commit real values — this file contains only placeholders.

# ── Database (Neon) ──────────────────────────────────────────────────────────
# From the Neon dashboard: Project → Connection string → Pooled connection
# Must include ?sslmode=require
DATABASE_URL="postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require"

# ── Auth.js ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="<32-byte base64 random string>"
# The canonical URL of the production deployment (no trailing slash)
NEXTAUTH_URL="https://your-domain.vercel.app"

# ── Google OAuth ─────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URI: https://your-domain.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="<your-google-client-id>.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="<your-google-client-secret>"

# ── Resend (email) ───────────────────────────────────────────────────────────
# From Resend dashboard → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL="noreply@shefa.jobs"

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
# From Upstash console → Database → REST URL (use the ioredis-compatible URL)
# Format: rediss://:password@host:port
REDIS_URL="rediss://:<password>@<host>.upstash.io:6379"

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV="production"
