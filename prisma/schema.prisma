generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SEEKER
  EMPLOYER
  ADMIN
}

enum ProfileStatus {
  ACTIVE
  PAUSED
  SUSPENDED
}

enum JobStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum JobClosureReason {
  FILLED_ON_SHEFA
  FILLED_ELSEWHERE
  HIRING_FROZEN
  CANCELLED
  OTHER
}

enum ApplicationStatus {
  SUBMITTED
  VIEWED
  REJECTED
  CLOSED
}

enum PingType {
  SEEKER_STILL_LOOKING
  JOB_STILL_OPEN
}

enum PingResponse {
  CONFIRMED
  NOT_LOOKING
  FILLED
  PAUSED
  NO_RESPONSE
}

enum ReportTargetType {
  USER
  JOB
  MESSAGE
}

enum ReportStatus {
  OPEN
  REVIEWED
  ACTIONED
  DISMISSED
}

enum NotificationFrequency {
  PER_MESSAGE
  DAILY_DIGEST
  OFF
}

enum JobType {
  FULL_TIME
  PART_TIME
  EITHER
}

enum WorkArrangement {
  REMOTE
  ON_SITE
  HYBRID
}

enum CompanySize {
  SIZE_1_10
  SIZE_11_50
  SIZE_51_200
  SIZE_201_PLUS
}

enum EducationLevel {
  NONE
  SOME_HIGH_SCHOOL
  HIGH_SCHOOL
  SOME_COLLEGE
  ASSOCIATE
  BACHELOR
  GRADUATE
}

enum Industry {
  FOOD_SERVICE
  RETAIL
  HOSPITALITY
  HEALTHCARE
  TRADES
  MANUFACTURING
  OFFICE_ADMIN
  TRANSPORTATION
  EDUCATION
  PERSONAL_SERVICES
  TECHNOLOGY
  BUSINESS
  FINANCE
  MARKETING
  MEDIA
  REAL_ESTATE
  OTHER
}

enum DayOfWeek {
  SUN
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())

  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  phone         String?
  role          Role?
  isAdult       Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth.js
  accounts Account[]
  sessions Session[]

  seekerProfile           SeekerProfile?
  employerProfile         EmployerProfile?
  companies               Company[]
  notificationPrefs       NotificationPreferences?
  jobs                    JobPosting[]
  applications            Application[]
  conversationsAsSeeker   Conversation[] @relation("ConversationSeeker")
  conversationsAsEmployer Conversation[] @relation("ConversationEmployer")
  sentMessages            Message[]
  verificationPings       VerificationPing[]
  reports                 Report[]

  @@index([role])
}

model SeekerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Required at signup
  firstName         String
  lastName          String
  city              String
  state             String
  workAuthorization Boolean
  availableDays     DayOfWeek[]
  jobSeekText       String      @db.VarChar(1000)

  // Optional / encouraged later
  educationLevel EducationLevel?
  otherSkills    String?
  otherLanguages String?
  about          String?         @db.VarChar(1000)
  resumeUrl      String?

  // System
  status         ProfileStatus @default(ACTIVE)
  lastVerifiedAt DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  languages         SeekerLanguage[]
  verificationPings VerificationPing[] @relation("SeekerPings")

  @@index([status])
}

model EmployerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName     String
  lastName      String
  roleAtCompany String? @db.VarChar(200)
  status         ProfileStatus @default(ACTIVE)

  isResponsive            Boolean   @default(false)
  responsivenessUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Company {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name         String
  city         String
  state        String
  website      String?
  industry     Industry?
  companySize  CompanySize?
  aboutCompany String?      @db.VarChar(2000)
  missionText  String?      @db.VarChar(1000)

  jobs JobPosting[]

  @@unique([ownerId, name])
  @@index([ownerId])
}

model JobPosting {
  id         String  @id @default(cuid())
  employerId String
  employer   User    @relation(fields: [employerId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title              String
  description        String          @db.VarChar(5000)
  jobType            JobType
  workArrangement    WorkArrangement
  city               String
  state              String
  lat                Float
  lon                Float
  minHourlyRate      Decimal         @db.Decimal(8, 2)
  payNotes           String?
  workDays           DayOfWeek[]
  scheduleNotes      String?
  workAuthRequired   Boolean
  whatWeTeach        String?         @db.VarChar(1000)
  whatWereLookingFor String?         @db.VarChar(1000)

  // System
  status         JobStatus        @default(ACTIVE)
  closureReason  JobClosureReason?
  closedAt       DateTime?
  lastVerifiedAt DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  requiredLanguages JobLanguage[]
  applications      Application[]
  conversations     Conversation[]
  verificationPings VerificationPing[] @relation("JobPings")

  @@index([status])
  @@index([employerId, status, createdAt])
  @@index([status, jobType])
  @@index([status, workArrangement])
  @@index([status, createdAt])
  @@index([employerId])
  @@index([companyId])
  @@index([lat, lon])
  @@index([closedAt])
}

model Application {
  id       String @id @default(cuid())
  seekerId String
  seeker   User   @relation(fields: [seekerId], references: [id])
  jobId    String
  job      JobPosting @relation(fields: [jobId], references: [id])

  message  String?           @db.VarChar(500)
  status   ApplicationStatus @default(SUBMITTED)
  closedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([seekerId, jobId])
  @@index([jobId, createdAt])
  @@index([jobId])
  @@index([status])
}

model Conversation {
  id         String      @id @default(cuid())
  seekerId   String
  seeker     User        @relation("ConversationSeeker", fields: [seekerId], references: [id], onDelete: Cascade)
  employerId String
  employer   User        @relation("ConversationEmployer", fields: [employerId], references: [id], onDelete: Cascade)
  jobId      String?
  job        JobPosting? @relation(fields: [jobId], references: [id])

  lastMessageAt      DateTime?
  lastMessagePreview String?   @db.VarChar(80)
  seekerBlocked      Boolean   @default(false)
  employerBlocked    Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  messages Message[]

  @@unique([seekerId, employerId, jobId])
  @@index([seekerId])
  @@index([employerId])
  @@index([seekerId, lastMessageAt])
  @@index([employerId, lastMessageAt])
  @@index([lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String       @db.VarChar(5000)
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
}

// ─── Freshness / Verification ─────────────────────────────────────────────────

model VerificationPing {
  id          String        @id @default(cuid())
  type        PingType
  sentAt      DateTime      @default(now())
  respondedAt DateTime?
  response    PingResponse?

  userId          String?
  user            User?          @relation(fields: [userId], references: [id])
  seekerProfileId String?
  seekerProfile   SeekerProfile? @relation("SeekerPings", fields: [seekerProfileId], references: [id])
  jobId           String?
  job             JobPosting?    @relation("JobPings", fields: [jobId], references: [id])

  freshnessTokens FreshnessToken[]

  @@index([userId])
  @@index([jobId])
}

model FreshnessToken {
  id         String            @id @default(cuid())
  token      String            @unique
  targetType String
  targetId   String
  action     PingResponse
  pingId     String?
  ping       VerificationPing? @relation(fields: [pingId], references: [id])
  expiresAt  DateTime
  usedAt     DateTime?

  @@index([targetType, targetId])
  @@index([expiresAt])
}

// ─── Auth.js ──────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Geography ────────────────────────────────────────────────────────────────

model State {
  id   String @id @default(cuid())
  name String @unique
  abbr String @unique
  lat  Float
  lon  Float

  cities City[]
}

model City {
  id      String @id @default(cuid())
  name    String
  stateId String
  state   State  @relation(fields: [stateId], references: [id])
  lat     Float
  lon     Float

  @@unique([name, stateId])
  @@index([stateId])
}

// ─── Taxonomy ─────────────────────────────────────────────────────────────────

model Language {
  id   String @id @default(cuid())
  name String @unique

  seekerLanguages SeekerLanguage[]
  jobLanguages    JobLanguage[]
}

model SeekerLanguage {
  seekerProfileId String
  seekerProfile   SeekerProfile @relation(fields: [seekerProfileId], references: [id])
  languageId      String
  language        Language      @relation(fields: [languageId], references: [id])

  @@id([seekerProfileId, languageId])
}

model JobLanguage {
  jobId      String
  job        JobPosting @relation(fields: [jobId], references: [id])
  languageId String
  language   Language   @relation(fields: [languageId], references: [id])

  @@id([jobId, languageId])
}

// ─── Notifications & Moderation ───────────────────────────────────────────────

model NotificationPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  messageNotifications     NotificationFrequency @default(PER_MESSAGE)
  applicationNotifications NotificationFrequency @default(PER_MESSAGE)
  updatedAt                DateTime              @updatedAt
}

model Report {
  id         String           @id @default(cuid())
  reporterId String
  reporter   User             @relation(fields: [reporterId], references: [id])
  targetType ReportTargetType
  targetId   String
  reason     String
  status     ReportStatus     @default(OPEN)
  createdAt  DateTime         @default(now())

  @@index([status])
  @@index([targetType, targetId])
}
