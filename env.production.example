# Production environment variables for Vercel + Neon + Resend.
# Copy the relevant vars into Vercel's environment settings.
# Never commit real values — this file contains only placeholders.

# ── Database (Neon) ──────────────────────────────────────────────────────────
# From the Neon dashboard: Project → Connection string → Pooled connection.
# Use the POOLED url for the app; must include ?sslmode=require.
DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.neon.tech/<dbname>?sslmode=require"

# ── Auth.js ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="<32-byte base64 random string>"
# Canonical URL of the production deployment, NO trailing slash. Read directly by the
# app for verification redirects and all outbound email links — REQUIRED in production
# (the app throws on startup paths if it's missing).
AUTH_URL="https://your-domain.com"

# ── Google OAuth ─────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials.
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID="<your-google-client-id>.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="<your-google-client-secret>"

# ── Resend (email) ───────────────────────────────────────────────────────────
# From the Resend dashboard → API Keys.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Verified sender address in your Resend account (used as the From address).
RESEND_FROM_EMAIL="noreply@meirgarfinkel.com"
ADMIN_EMAIL="shefa@meirgarfinkel.com"

# ── Vercel Cron auth ─────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# REQUIRED. The cron routes reject every request when this is unset (fail-closed), so
# the freshness / responsiveness / digest jobs won't run until it's set in Vercel.
CRON_SECRET="<random hex secret>"

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV="production"

# ── Google Indexing API (optional) ───────────────────────────────────────────
# Instantly notifies Google when a job posting is created/updated/closed.
# Setup: GCP project → enable "Web Search Indexing API" → create a service account +
# JSON key → in Google Search Console add the service-account email as a verified Owner
# of the property. Then copy these two fields from the downloaded JSON key.
# If unset, indexing notifications are silently skipped (the sitemap still works).
GOOGLE_INDEXING_CLIENT_EMAIL="<name>@<project>.iam.gserviceaccount.com"
# The full PEM, on ONE line, with newlines escaped as \n (paste the JSON "private_key" value verbatim).
GOOGLE_INDEXING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
