{
  "name": "shefa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "db:dev-reset": "npx dotenv -e .env -- sh -c 'psql \"$DATABASE_URL\" -c \"DROP SCHEMA IF EXISTS public CASCADE; DROP SCHEMA IF EXISTS drizzle CASCADE; CREATE SCHEMA public;\" && rm -rf drizzle && npx drizzle-kit generate && npx drizzle-kit migrate && psql \"$DATABASE_URL\" -f src/db/manual/trgm_search_indexes.sql && tsx src/db/scripts/seed.ts'",
    "db:prod-reset": "npx dotenv -e .env.production -- sh -c 'psql \"$DATABASE_URL\" -c \"DROP SCHEMA IF EXISTS public CASCADE; DROP SCHEMA IF EXISTS drizzle CASCADE; CREATE SCHEMA public;\" && rm -rf drizzle && npx drizzle-kit generate && npx drizzle-kit migrate && psql \"$DATABASE_URL\" -f src/db/manual/trgm_search_indexes.sql && tsx src/db/scripts/seed.ts'",
    "db:dev-index": "npx dotenv -e .env -- sh -c 'psql \"$DATABASE_URL\" -f src/db/manual/trgm_search_indexes.sql'",
    "db:prod-index": "npx dotenv -e .env.production -- sh -c 'psql \"$DATABASE_URL\" -f src/db/manual/trgm_search_indexes.sql'",
    "db:seed": "tsx src/db/scripts/seed.ts",
    "db:seed:jobs": "tsx src/db/scripts/seed-jobs.ts",
    "db:prod-seed": "npx dotenv -e .env.production -- tsx src/db/scripts/seed.ts",
    "db:prod-seed:jobs": "npx dotenv -e .env.production -- tsx src/db/scripts/seed-jobs.ts",
    "db:dev-generate": "npx dotenv -e .env -- npx drizzle-kit generate",
    "db:dev-migrate": "npx dotenv -e .env -- npx drizzle-kit migrate",
    "db:prod-generate": "npx dotenv -e .env.production -- npx drizzle-kit generate",
    "db:prod-migrate": "npx dotenv -e .env.production -- npx drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^0.10.4",
    "@paralleldrive/cuid2": "^2.2.2",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.5",
    "@trpc/client": "^11.13.0",
    "@trpc/react-query": "^11.13.0",
    "@trpc/server": "^11.13.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.11.0",
    "next": "15.5.15",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.74.0",
    "resend": "^6.12.2",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
